<%- include('partials/header') %>
<div class="flex min-h-svh flex-col items-center justify-center p-6 md:p-10 bg-background relative overflow-hidden">
  <!-- Glowing background elements -->
  <div class="absolute inset-0 pointer-events-none opacity-40">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full bg-blue-500/10 blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 rounded-full bg-violet-500/10 blur-3xl"></div>
  </div>

  <div class="w-full max-w-md relative z-10 animate-slide-up">
    <div class="glass-card rounded-2xl p-8 text-center flex flex-col items-center gap-6">
      
      <!-- Animated Error Icon -->
      <div class="size-16 rounded-2xl bg-destructive/10 text-destructive flex items-center justify-center shadow-lg shadow-destructive/5 animate-pulse">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
          <line x1="12" y1="9" x2="12" y2="13"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
      </div>

      <!-- Error Headers -->
      <div class="space-y-2">
        <h1 class="text-6xl font-extrabold tracking-tighter text-foreground font-mono">
          <%= error && error.status ? error.status : 'Error' %>
        </h1>
        <h2 class="text-xl font-bold text-foreground leading-tight">
          <%= message || 'Terjadi Kesalahan Sistem' %>
        </h2>
        <p class="text-sm text-muted-foreground max-w-xs mx-auto">
          Maaf, halaman yang Anda cari tidak dapat diakses atau sedang mengalami gangguan teknis.
        </p>
      </div>

      <!-- Action Button -->
      <div class="w-full pt-2">
        <a href="/home" class="btn w-full text-white inline-flex justify-center items-center h-10" data-variant="default" style="border-radius: 12px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="mr-2">
            <path d="m12 19-7-7 7-7"/>
            <path d="M19 12H5"/>
          </svg>
          Kembali ke Dashboard
        </a>
      </div>

      <!-- Developer Stack Trace (Collapsible) -->
      <% if (error && error.stack && Object.keys(error).length > 0) { %>
        <div class="w-full text-left mt-4 border-t border-muted/30 pt-4">
          <details class="group cursor-pointer">
            <summary class="text-xs font-semibold text-muted-foreground flex items-center justify-between select-none">
              <span>Detail Teknis (Developer Mode)</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="group-open:rotate-180 transition-transform">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </summary>
            <div class="mt-2 text-xs font-mono bg-muted/65 p-3 rounded-lg overflow-x-auto text-muted-foreground max-h-40 border border-muted/50 leading-relaxed">
              <%= error.stack %>
            </div>
          </details>
        </div>
      <% } %>

    </div>

    <!-- Subtext Branding -->
    <p class="text-xs text-muted-foreground text-center mt-6">
      &copy; 2025 Fakultas Teknologi Informasi — Universitas Andalas
    </p>
  </div>
</div>
<%- include('partials/footer') %>
