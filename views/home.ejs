<%- include('partials/header') %>
<%- include('partials/sidebar') %>
<main id="content">
  <%- include('partials/navbar') %>

  <!-- Outer layout wrapper with ambient glow -->
  <div class="container mx-auto p-6 md:p-10 space-y-8 animate-slide-up relative">
    
    <!-- Premium ambient glowing backgrounds -->
    <div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-primary/5 rounded-full blur-[100px] pointer-events-none animate-pulse-slow"></div>
    <div class="absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-80 h-80 bg-indigo-500/5 rounded-full blur-[100px] pointer-events-none animate-pulse-slow"></div>

    <!-- 1. Welcoming Hero Banner -->
    <div class="glass-card rounded-2xl p-6 md:p-10 border border-white/10 dark:border-white/5 relative z-10 shadow-xl text-left bg-gradient-to-r from-card/80 via-card/90 to-primary/5">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="space-y-2">
          <h1 class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl leading-tight" style="font-family: 'Plus Jakarta Sans', sans-serif !important; letter-spacing: -0.03em;">
            Selamat Datang, <span class="bg-gradient-to-r from-blue-600 to-indigo-600 dark:from-blue-400 dark:to-indigo-400 bg-clip-text text-transparent inline-block font-extrabold"><%= employee ? employee.name : 'Pegawai' %></span>! 👋
          </h1>
          <p class="text-muted-foreground text-sm md:text-base font-medium max-w-xl">
            Kelola data portofolio akademik, aktivitas penelitian, publikasi, dan pengabdian masyarakat Anda secara terpadu di platform **B7-Profile**.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="/portfolio" class="btn shrink-0" data-slot="button" data-variant="default" style="border-radius: 12px;" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
            Lihat Portofolio
          </a>
          <a href="/portfolio/pdf" class="btn shrink-0" data-slot="button" data-variant="secondary" style="border-radius: 12px;">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            Cetak PDF
          </a>
        </div>
      </div>
    </div>

    <!-- 2. Statistics Grid Dashboard -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 relative z-10">
      
      <!-- Stat 1: Pendidikan -->
      <div class="glass-card rounded-2xl p-5 md:p-6 border border-white/10 hover:border-blue-500/20 dark:hover:border-blue-500/30 transition-all duration-300 shadow-md group">
        <div class="flex items-center justify-between">
          <div class="space-y-1">
            <p class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Pendidikan</p>
            <h3 class="text-3xl font-extrabold text-foreground tracking-tight group-hover:text-blue-500 transition-colors"><%= stats.education %></h3>
          </div>
          <div class="p-3 bg-blue-500/10 rounded-xl text-blue-600 dark:text-blue-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /></svg>
          </div>
        </div>
        <p class="text-xs text-muted-foreground mt-3">Riwayat gelar akademik</p>
      </div>

      <!-- Stat 2: Penelitian -->
      <div class="glass-card rounded-2xl p-5 md:p-6 border border-white/10 hover:border-indigo-500/20 dark:hover:border-indigo-500/30 transition-all duration-300 shadow-md group">
        <div class="flex items-center justify-between">
          <div class="space-y-1">
            <p class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Penelitian</p>
            <h3 class="text-3xl font-extrabold text-foreground tracking-tight group-hover:text-indigo-500 transition-colors"><%= stats.research %></h3>
          </div>
          <div class="p-3 bg-indigo-500/10 rounded-xl text-indigo-600 dark:text-indigo-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
          </div>
        </div>
        <p class="text-xs text-muted-foreground mt-3">Proyek riset ilmiah</p>
      </div>

      <!-- Stat 3: Publikasi -->
      <div class="glass-card rounded-2xl p-5 md:p-6 border border-white/10 hover:border-purple-500/20 dark:hover:border-purple-500/30 transition-all duration-300 shadow-md group">
        <div class="flex items-center justify-between">
          <div class="space-y-1">
            <p class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Publikasi</p>
            <h3 class="text-3xl font-extrabold text-foreground tracking-tight group-hover:text-purple-500 transition-colors"><%= stats.publications %></h3>
          </div>
          <div class="p-3 bg-purple-500/10 rounded-xl text-purple-600 dark:text-purple-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.168.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
          </div>
        </div>
        <p class="text-xs text-muted-foreground mt-3">Jurnal dan karya tulis ilmiah</p>
      </div>

      <!-- Stat 4: Pengabdian -->
      <div class="glass-card rounded-2xl p-5 md:p-6 border border-white/10 hover:border-emerald-500/20 dark:hover:border-emerald-500/30 transition-all duration-300 shadow-md group">
        <div class="flex items-center justify-between">
          <div class="space-y-1">
            <p class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Pengabdian & Panitia</p>
            <h3 class="text-3xl font-extrabold text-foreground tracking-tight group-hover:text-emerald-500 transition-colors"><%= stats.services + stats.committees %></h3>
          </div>
          <div class="p-3 bg-emerald-500/10 rounded-xl text-emerald-600 dark:text-emerald-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
          </div>
        </div>
        <p class="text-xs text-muted-foreground mt-3">Kegiatan masyarakat & kepanitiaan</p>
      </div>

    </div>

    <!-- 3. Profil Singkat & Status Sistem Section (Split Layout) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative z-10 text-left">
      
      <!-- Profil Singkat Card (Left 2 Columns) -->
      <div class="glass-card rounded-2xl p-6 md:col-span-2 space-y-6 shadow-lg border border-white/10">
        <h2 class="text-xl font-bold text-foreground border-b pb-2 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
          Profil Singkat Pegawai
        </h2>
        
        <% if (employee) { %>
        <div class="flex flex-col sm:flex-row gap-6 items-center sm:items-start">
          <img
            src="<%= employee.photo ? '/uploads/' + employee.photo : '/assets/images/placeholder.svg' %>"
            class="rounded-full border-2 border-muted bg-card shadow-sm object-cover"
            style="width: 100px; height: 100px;"
            alt="Foto Profil"
          />
          <div class="flex-1 space-y-4 w-full">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-3 gap-x-4 text-sm">
              <div>
                <span class="block text-xs text-muted-foreground font-semibold uppercase">Nama Lengkap</span>
                <span class="text-foreground font-bold text-base"><%= employee.name %></span>
              </div>
              <div>
                <span class="block text-xs text-muted-foreground font-semibold uppercase">NIP</span>
                <span class="text-foreground font-semibold"><%= employee.employee_number || '-' %></span>
              </div>
              <div>
                <span class="block text-xs text-muted-foreground font-semibold uppercase">Unit Kerja / Departemen</span>
                <span class="text-foreground"><%= employee.org_unit_name || '-' %></span>
              </div>
              <div>
                <span class="block text-xs text-muted-foreground font-semibold uppercase">Status Kepegawaian</span>
                <span class="text-foreground inline-flex items-center rounded-full bg-emerald-500/10 px-2 py-0.5 text-xs font-semibold text-emerald-600 dark:text-emerald-500 border border-emerald-500/20 mt-0.5">
                  <%= employee.emp_status_name || '-' %>
                </span>
              </div>
            </div>
            
            <div class="pt-2">
              <a href="/profile/edit" class="btn-sm text-xs" data-slot="button" data-variant="outline" style="border-radius: 8px;" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
                <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                Perbarui Informasi Profil
              </a>
            </div>
          </div>
        </div>
        <% } else { %>
          <div class="text-center py-6 text-muted-foreground">Data pegawai tidak ditemukan.</div>
        <% } %>
      </div>

      <!-- Informasi Sistem & REST API (Right 1 Column) -->
      <div class="glass-card rounded-2xl p-6 space-y-4 shadow-lg border border-white/10 flex flex-col justify-between">
        <div class="space-y-4">
          <h2 class="text-xl font-bold text-foreground border-b pb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            Status Sistem
          </h2>
          <div class="space-y-3 text-xs">
            <div class="flex items-center justify-between py-1 border-b border-muted/20">
              <span class="text-muted-foreground">Database MySQL</span>
              <span class="text-emerald-500 font-bold flex items-center gap-1">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                </span>
                Terhubung
              </span>
            </div>
            <div class="flex items-center justify-between py-1 border-b border-muted/20">
              <span class="text-muted-foreground">REST API GET</span>
              <a href="/api/portfolio" class="text-primary hover:underline font-bold" target="_blank">Aktif (/api/portfolio)</a>
            </div>
            <div class="flex items-center justify-between py-1">
              <span class="text-muted-foreground">Mode App</span>
              <span class="font-bold text-muted-foreground uppercase">Production Ready</span>
            </div>
          </div>
        </div>
        
        <div class="pt-4 border-t border-muted/20">
          <div class="p-3 bg-muted/30 rounded-xl text-[11px] text-muted-foreground leading-relaxed">
            💡 **Tips Sidang:** Untuk demo data format JSON, login terlebih dahulu lalu buka link `/api/portfolio` pada tab baru browser Anda.
          </div>
        </div>
      </div>

    </div>

  </div>
</main>
<%- include('partials/footer') %>
