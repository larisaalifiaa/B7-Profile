<%- include('partials/header') %>
<%- include('partials/sidebar') %>
<main id="content">
  <%- include('partials/navbar') %>

  <!-- Outer layout wrapper with ambient glow -->
  <div class="container mx-auto p-6 md:p-10 space-y-8 animate-slide-up relative">
    
    <!-- Premium ambient glowing backgrounds -->
    <div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-primary/5 rounded-full blur-[100px] pointer-events-none animate-pulse-slow"></div>
    <div class="absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-80 h-80 bg-indigo-500/5 rounded-full blur-[100px] pointer-events-none animate-pulse-slow"></div>

    <!-- 1. Dashboard Welcoming Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 relative z-10 text-left animate-slide-up">
      <div class="space-y-2">
        <h1 class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl" style="font-family: 'Plus Jakarta Sans', sans-serif !important; letter-spacing: -0.025em;">
          Halo, <%= employee ? employee.name : 'Pegawai' %>! 👋
        </h1>
        <p class="text-sm text-muted-foreground">
          Berikut adalah ringkasan aktivitas akademik dan data portofolio Anda.
        </p>
      </div>
      <div class="flex shrink-0">
        <a href="/portfolio" class="btn" data-slot="button" data-variant="default" style="border-radius: 12px;" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
          Lihat Portofolio
        </a>
      </div>
    </div>

    <!-- 2. Statistics Grid Dashboard (Responsive 3 Columns Grid) -->
    <div class="dashboard-grid relative z-10 animate-slide-up animate-slide-up-1">
      
      <!-- Stat 1: Pendidikan -->
      <div class="dashboard-stat-card rounded-3xl p-6 flex flex-col items-center justify-center relative group" style="min-height: 140px;">
        <!-- Top accent color strip -->
        <div class="absolute top-0 inset-x-0 h-1.5 bg-gradient-to-r from-blue-500 to-indigo-500 rounded-t-3xl"></div>
        
        <!-- Thematic Background Element -->
        <svg xmlns="http://www.w3.org/2000/svg" class="bg-icon" style="color: #3b82f6;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path d="M12 14l9-5-9-5-9 5 9 5z" />
          <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
        </svg>

        <span class="text-[11px] font-bold text-muted-foreground uppercase tracking-widest mb-3 flex items-center gap-1.5">
          <span class="size-1.5 rounded-full bg-blue-500 animate-pulse"></span>
          Pendidikan
        </span>
        <span class="text-4xl font-extrabold text-foreground tracking-tight group-hover:scale-105 transition-transform duration-300 relative z-10">
          <%= stats.education %>
        </span>
        <span class="text-[10px] text-muted-foreground/60 mt-2 font-medium">Riwayat Pendidikan</span>
      </div>

      <!-- Stat 2: Penelitian -->
      <div class="dashboard-stat-card rounded-3xl p-6 flex flex-col items-center justify-center relative group" style="min-height: 140px;">
        <!-- Top accent color strip -->
        <div class="absolute top-0 inset-x-0 h-1.5 bg-gradient-to-r from-emerald-500 to-teal-500 rounded-t-3xl"></div>
        
        <!-- Thematic Background Element -->
        <svg xmlns="http://www.w3.org/2000/svg" class="bg-icon" style="color: #10b981;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
        </svg>

        <span class="text-[11px] font-bold text-muted-foreground uppercase tracking-widest mb-3 flex items-center gap-1.5">
          <span class="size-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
          Penelitian
        </span>
        <span class="text-4xl font-extrabold text-foreground tracking-tight group-hover:scale-105 transition-transform duration-300 relative z-10">
          <%= stats.research %>
        </span>
        <span class="text-[10px] text-muted-foreground/60 mt-2 font-medium">Proyek Penelitian</span>
      </div>

      <!-- Stat 3: Publikasi -->
      <div class="dashboard-stat-card rounded-3xl p-6 flex flex-col items-center justify-center relative group" style="min-height: 140px;">
        <!-- Top accent color strip -->
        <div class="absolute top-0 inset-x-0 h-1.5 bg-gradient-to-r from-violet-500 to-purple-500 rounded-t-3xl"></div>
        
        <!-- Thematic Background Element -->
        <svg xmlns="http://www.w3.org/2000/svg" class="bg-icon" style="color: #8b5cf6;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.168.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>

        <span class="text-[11px] font-bold text-muted-foreground uppercase tracking-widest mb-3 flex items-center gap-1.5">
          <span class="size-1.5 rounded-full bg-violet-500 animate-pulse"></span>
          Publikasi
        </span>
        <span class="text-4xl font-extrabold text-foreground tracking-tight group-hover:scale-105 transition-transform duration-300 relative z-10">
          <%= stats.publications %>
        </span>
        <span class="text-[10px] text-muted-foreground/60 mt-2 font-medium">Karya Ilmiah & Jurnal</span>
      </div>

      <!-- Stat 4: Pengabdian Masyarakat -->
      <div class="dashboard-stat-card rounded-3xl p-6 flex flex-col items-center justify-center relative group" style="min-height: 140px;">
        <!-- Top accent color strip -->
        <div class="absolute top-0 inset-x-0 h-1.5 bg-gradient-to-r from-amber-500 to-orange-500 rounded-t-3xl"></div>
        
        <!-- Thematic Background Element -->
        <svg xmlns="http://www.w3.org/2000/svg" class="bg-icon" style="color: #f59e0b;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>

        <span class="text-[11px] font-bold text-muted-foreground uppercase tracking-widest mb-3 flex items-center gap-1.5">
          <span class="size-1.5 rounded-full bg-amber-500 animate-pulse"></span>
          Pengabdian
        </span>
        <span class="text-4xl font-extrabold text-foreground tracking-tight group-hover:scale-105 transition-transform duration-300 relative z-10">
          <%= stats.services %>
        </span>
        <span class="text-[10px] text-muted-foreground/60 mt-2 font-medium">Pengabdian Masyarakat</span>
      </div>

      <!-- Stat 5: Kepanitiaan -->
      <div class="dashboard-stat-card rounded-3xl p-6 flex flex-col items-center justify-center relative group" style="min-height: 140px;">
        <!-- Top accent color strip -->
        <div class="absolute top-0 inset-x-0 h-1.5 bg-gradient-to-r from-rose-500 to-pink-500 rounded-t-3xl"></div>
        
        <!-- Thematic Background Element -->
        <svg xmlns="http://www.w3.org/2000/svg" class="bg-icon" style="color: #f43f5e;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>

        <span class="text-[11px] font-bold text-muted-foreground uppercase tracking-widest mb-3 flex items-center gap-1.5">
          <span class="size-1.5 rounded-full bg-rose-500 animate-pulse"></span>
          Kepanitiaan
        </span>
        <span class="text-4xl font-extrabold text-foreground tracking-tight group-hover:scale-105 transition-transform duration-300 relative z-10">
          <%= stats.committees %>
        </span>
        <span class="text-[10px] text-muted-foreground/60 mt-2 font-medium">Kegiatan Kepanitiaan</span>
      </div>

      <!-- Stat 6: Riwayat Penugasan -->
      <div class="dashboard-stat-card rounded-3xl p-6 flex flex-col items-center justify-center relative group" style="min-height: 140px;">
        <!-- Top accent color strip -->
        <div class="absolute top-0 inset-x-0 h-1.5 bg-gradient-to-r from-cyan-500 to-sky-500 rounded-t-3xl"></div>
        
        <!-- Thematic Background Element -->
        <svg xmlns="http://www.w3.org/2000/svg" class="bg-icon" style="color: #06b6d4;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
        </svg>

        <span class="text-[11px] font-bold text-muted-foreground uppercase tracking-widest mb-3 flex items-center gap-1.5">
          <span class="size-1.5 rounded-full bg-cyan-500 animate-pulse"></span>
          Penugasan
        </span>
        <span class="text-4xl font-extrabold text-foreground tracking-tight group-hover:scale-105 transition-transform duration-300 relative z-10">
          <%= stats.assignments %>
        </span>
        <span class="text-[10px] text-muted-foreground/60 mt-2 font-medium">Surat Tugas & Penugasan</span>
      </div>

    </div>

  </div>
</main>
<%- include('partials/footer') %>
