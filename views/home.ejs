<%- include('partials/header') %>
<%- include('partials/sidebar') %>
<main id="content">
  <%- include('partials/navbar') %>

  <!-- Outer layout wrapper with ambient glow -->
  <div class="container mx-auto p-6 md:p-12 max-w-4xl flex flex-col justify-center min-h-[calc(100vh-140px)] relative animate-slide-up">
    
    <!-- Premium ambient glowing backgrounds -->
    <div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-primary/10 rounded-full blur-[100px] pointer-events-none animate-pulse-slow"></div>
    <div class="absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-80 h-80 bg-indigo-500/10 rounded-full blur-[100px] pointer-events-none animate-pulse-slow"></div>

    <!-- Main Welcoming Card -->
    <div class="glass-card rounded-3xl overflow-hidden p-10 md:p-16 max-w-2xl ml-0 w-full border border-white/10 dark:border-white/5 relative z-10 shadow-2xl text-left">
      <h1 class="text-3xl font-extrabold tracking-tight text-foreground md:text-5xl leading-tight" style="font-family: 'Plus Jakarta Sans', sans-serif !important; letter-spacing: -0.03em;">
        Halo, <span class="bg-gradient-to-r from-blue-600 to-indigo-600 dark:from-blue-400 dark:to-indigo-400 bg-clip-text text-transparent inline-block font-extrabold"><%= user ? user.name : 'Pegawai' %></span>! 👋
      </h1>
    </div>
  </div>
</main>
<%- include('partials/footer') %>
