<%- include('partials/header') %>
<%- include('partials/sidebar') %>
<main id="content">
  <%- include('partials/navbar') %>

  <div class="container mx-auto p-6 md:p-10 space-y-6">
    <!-- Breadcrumbs & Heading -->
    <div class="flex flex-col gap-1">
      <div class="flex items-center gap-2 text-xs font-semibold text-muted-foreground uppercase tracking-wider">
        <a href="/home" class="hover:text-foreground transition-colors" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Dashboard</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="size-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <span class="text-primary">Ubah Password</span>
      </div>
      <h1 class="text-3xl font-extrabold tracking-tight text-foreground mt-1">Ubah Password</h1>
    </div>

    <!-- Alerts -->
    <% if (error) { %>
      <div class="alert-error flex items-center gap-3 text-sm font-medium animate-slide-up">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        <%= error %>
      </div>
    <% } %>
    <% if (success) { %>
      <div class="alert-success flex items-center gap-3 text-sm font-semibold animate-slide-up">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <%= success %>
      </div>
    <% } %>

    <div class="glass-card rounded-2xl overflow-hidden max-w-md mx-auto animate-slide-up">
      <div class="p-6 border-b border-border flex items-center gap-3">
        <div class="stat-icon" style="width:34px;height:34px;border-radius:10px;background:rgba(245,158,11,0.08);color:#f59e0b;">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m21 2-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
        </div>
        <div>
          <h2 class="text-base font-bold text-foreground">Keamanan Akun</h2>
          <p class="text-xs text-muted-foreground">Pastikan password baru Anda kuat dan mudah diingat</p>
        </div>
      </div>
      <form action="/profile/password" method="POST" onsubmit="return validatePasswords()" class="p-8 space-y-6">

        <div class="space-y-2 flex flex-col">
          <label for="current_password" class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Password Lama</label>
          <div class="password-wrapper">
            <input type="password" id="current_password" name="current_password" class="input-premium h-11" placeholder="Masukkan password lama Anda" required />
            <button type="button" class="password-toggle" onclick="togglePasswordVisibility('current_password')" aria-label="Tampilkan password">
              <svg id="eye-icon-current_password" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="space-y-2 flex flex-col">
          <label for="new_password" class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Password Baru</label>
          <div class="password-wrapper">
            <input type="password" id="new_password" name="new_password" class="input-premium h-11" placeholder="Masukkan password baru" minlength="6" required />
            <button type="button" class="password-toggle" onclick="togglePasswordVisibility('new_password')" aria-label="Tampilkan password">
              <svg id="eye-icon-new_password" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
          <p class="text-xs text-muted-foreground mt-1">Minimal 6 karakter</p>
        </div>

        <div class="space-y-2 flex flex-col">
          <label for="confirm_password" class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Konfirmasi Password Baru</label>
          <div class="password-wrapper">
            <input type="password" id="confirm_password" name="confirm_password" class="input-premium h-11" placeholder="Konfirmasi password baru Anda" required />
            <button type="button" class="password-toggle" onclick="togglePasswordVisibility('confirm_password')" aria-label="Tampilkan password">
              <svg id="eye-icon-confirm_password" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="flex justify-end gap-3 pt-6 border-t border-border">
          <a href="/home" class="btn border px-5 py-2 text-sm" data-variant="outline" style="border-radius: 12px;" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Kembali</a>
          <button type="submit" class="btn text-white px-5 py-2 text-sm" data-variant="default" style="border-radius: 12px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="mr-2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Update Password
          </button>
        </div>
      </form>
    </div>
    </div>
  </div>

  <script>
    function showToast(title, message, category = 'error') {
      document.dispatchEvent(new CustomEvent('basecoat:toast', {
        detail: {
          config: {
            category: category,
            title: title,
            description: message,
            duration: 4000
          }
        }
      }));
    }

    function validatePasswords() {
      const newPassword = document.getElementById("new_password").value;
      const confirmPassword = document.getElementById("confirm_password").value;
      if (newPassword.length < 6) {
        showToast("Validasi Gagal", "Password baru minimal harus 6 karakter!", "error");
        return false;
      }
      if (newPassword !== confirmPassword) {
        showToast("Validasi Gagal", "Konfirmasi password baru tidak cocok!", "error");
        return false;
      }
      return true;
    }

    function togglePasswordVisibility(id) {
      const input = document.getElementById(id);
      const icon = document.getElementById('eye-icon-' + id);
      if (input.type === 'password') {
        input.type = 'text';
        icon.innerHTML = '<path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.52 13.52 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" y1="2" x2="22" y2="22"/>';
      } else {
        input.type = 'password';
        icon.innerHTML = '<path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0z"/><circle cx="12" cy="12" r="3"/>';
      }
    }
  </script>
</main>
<%- include('partials/footer') %>
