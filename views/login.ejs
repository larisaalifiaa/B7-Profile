<!doctype html>
<html lang="id">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (
            stored
              ? stored === "dark"
              : matchMedia("(prefers-color-scheme: dark)").matches
          ) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}

        const apply = (dark) => {
          document.documentElement.classList.toggle("dark", dark);
          try {
            localStorage.setItem("themeMode", dark ? "dark" : "light");
          } catch (_) {}
        };

        document.addEventListener("basecoat:theme", (event) => {
          const mode = event.detail?.mode;
          apply(
            mode === "dark"
              ? true
              : mode === "light"
                ? false
                : !document.documentElement.classList.contains("dark"),
          );
        });
      })();
    </script>

    <script>
      (function () {
        try {
          const storedTheme = localStorage.getItem("themeVariant");
          if (storedTheme)
            document.documentElement.classList.add(`theme-${storedTheme}`);
        } catch (event) {
          console.error(
            "Could not apply theme variant from localStorage",
            event,
          );
        }
      })();
    </script>

    <meta charset="utf-8" />
    <meta http-equiv="Content-Language" content="id" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Login — Sistem Informasi Kepegawaian FTI</title>
    <meta name="description" content="Portal masuk Sistem Informasi Kepegawaian Fakultas Teknologi Informasi — Universitas Andalas." />

    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/styles.css" />
    <link rel="stylesheet" href="/stylesheets/style.css" />

    <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>

    <style>
      .login-gradient-bg {
        background: linear-gradient(135deg, 
          hsl(var(--background)) 0%, 
          hsl(var(--muted)) 50%,
          hsl(var(--background)) 100%
        );
        position: relative;
      }
      .login-gradient-bg::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at top right, hsl(var(--primary) / 0.06), transparent 60%),
                    radial-gradient(ellipse at bottom left, hsl(var(--primary) / 0.04), transparent 60%);
        pointer-events: none;
      }
      .login-card {
        backdrop-filter: blur(12px);
        box-shadow: 0 25px 50px -12px rgba(0,0,0,0.1), 0 0 0 1px hsl(var(--border) / 0.5);
      }
      .login-hero-side {
        background: linear-gradient(135deg, #2563eb, #6366f1, #8b5cf6);
        position: relative;
        overflow: hidden;
      }
      .login-hero-side::before {
        content: '';
        position: absolute;
        inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.07'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
      }
      .login-hero-side img {
        position: relative; z-index: 1;
        mix-blend-mode: overlay;
        opacity: 0.3;
      }
      .login-float {
        animation: loginFloat 6s ease-in-out infinite;
      }
      @keyframes loginFloat {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px); }
      }
    </style>
  </head>
  <body class="bg-background">
    <div class="login-gradient-bg flex min-h-svh flex-col items-center justify-center p-6 md:p-10">
      <div class="w-full max-w-sm md:max-w-4xl relative z-10">
        <div class="flex flex-col gap-6">
          <div class="login-card flex flex-col gap-6 rounded-2xl border bg-card text-card-foreground overflow-hidden p-0">
            <div data-slot="card-content" class="grid p-0 md:grid-cols-2">
              <form class="p-8 md:p-10" action="/login" method="POST">
                <div class="flex w-full flex-col gap-6">
                  <!-- Branding -->
                  <div class="flex flex-col items-center gap-3 text-center">
                    <div class="flex items-center gap-2 mb-1">
                      <div class="bg-gradient-to-tr from-blue-600 to-violet-600 text-white flex aspect-square size-10 items-center justify-center rounded-xl shadow-lg login-float">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/></svg>
                      </div>
                    </div>
                    <h1 class="text-2xl font-extrabold text-foreground tracking-tight leading-tight">Selamat Datang</h1>
                    <p class="text-sm text-muted-foreground font-medium leading-relaxed max-w-xs">
                      Masuk ke Sistem Informasi Kepegawaian<br/>Fakultas Teknologi Informasi
                    </p>
                  </div>
                  
                  <% if (error) { %>
                    <div class="alert-error flex items-center gap-2 text-sm font-medium">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                      <%= error %>
                    </div>
                  <% } %>
                  <!-- Username -->
                  <div class="flex flex-col gap-2.5">
                    <label for="username" class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Username</label>
                    <input
                      type="text"
                      name="username"
                      class="input-premium h-11"
                      id="username"
                      placeholder="Masukkan username..."
                      required
                    />
                  </div>

                  <!-- Password -->
                  <div class="flex flex-col gap-2.5">
                    <div class="flex items-center justify-between">
                      <label for="password" class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Password</label>
                    </div>
                    <div class="password-wrapper">
                      <input
                        type="password"
                        name="password"
                        class="input-premium h-11"
                        id="password"
                        placeholder="••••••••"
                        required
                      />
                      <button type="button" class="password-toggle" onclick="togglePasswordVisibility('password')" aria-label="Tampilkan password">
                        <svg id="eye-icon-password" class="size-4.5" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0z"/>
                          <circle cx="12" cy="12" r="3"/>
                        </svg>
                      </button>
                    </div>
                  </div>

                  <!-- Submit -->
                  <button
                    data-slot="button"
                    data-variant="default"
                    class="inline-flex shrink-0 items-center justify-center gap-2 rounded-xl text-sm font-bold whitespace-nowrap h-11 px-6 py-2 bg-primary text-primary-foreground hover:bg-primary/90 transition-all shadow-md hover:shadow-lg"
                    type="submit"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                    Masuk
                  </button>
                </div>
              </form>
              
              <!-- Hero Side -->
              <div class="login-hero-side relative hidden md:flex flex-col items-center justify-center p-10 text-center">
                <div class="relative z-10 space-y-4">
                  <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-3 login-float"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/></svg>
                    <h3 class="text-white text-xl font-extrabold">Sistem Informasi</h3>
                    <h3 class="text-white text-xl font-extrabold">Kepegawaian</h3>
                    <p class="text-white/70 text-sm font-medium mt-2 max-w-[200px] mx-auto">Kelola data profil dan portofolio akademik dengan mudah</p>
                  </div>
                  <p class="text-white/50 text-xs font-medium">FTI HC — Universitas Andalas</p>
                </div>
              </div>
            </div>
          </div>
          <p class="text-xs text-muted-foreground text-center font-medium">
            &copy; 2025 Fakultas Teknologi Informasi — Universitas Andalas
          </p>
        </div>
      </div>
    </div>
    <script>
      function togglePasswordVisibility(id) {
        const input = document.getElementById(id);
        const icon = document.getElementById('eye-icon-' + id);
        if (input.type === 'password') {
          input.type = 'text';
          icon.innerHTML = '<path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.52 13.52 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" y1="2" x2="22" y2="22"/>';
        } else {
          input.type = 'password';
          icon.innerHTML = '<path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0z"/><circle cx="12" cy="12" r="3"/>';
        }
      }
    </script>
    <div id="toaster" class="toaster"></div>
  </body>
</html>
